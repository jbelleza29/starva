# Copy to .env.local and fill in. All values are optional for local dev:
# with no MONGODB_URI the app serves a built-in sample dataset.

# MongoDB connection string (e.g. a free MongoDB Atlas cluster)
MONGODB_URI=

# Strava API credentials — only needed to sync real activity data.
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback
